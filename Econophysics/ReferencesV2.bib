author = {M.H. Vainstein and R. Morgado and F.A. Oliveira and F.A.B.F. {de Moura} and M.D. Coutinho-Filho},
abstract = {We study the diffusion process in a Heisenberg chain with correlated spatial disorder, with a power spectrum in the momentum space behaving as k\\xe2\\x88\\x92\\xce\\xb2, using a stochastic description. It establishes a direct connection between the fluctuation in the spin-wave density of states and the noise density of states. For continuous ranges of the exponent \\xce\\xb2, we find superdiffusive and ballistic spin-wave motions. Both diffusion exponents predicted by the stochastic procedure agree with the ones calculated using the Hamiltonian dynamics.}
}
